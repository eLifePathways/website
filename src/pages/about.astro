---
import "../styles/main.css";
import ContentSection from "../components/ContentSection.astro";
import Footer from "../components/Footer.astro";
import MobileNav from "../components/MobileNav.astro";
import PageHead from "../components/PageHead.astro";
import PageHero from "../components/PageHero.astro";
import MetaTags from "../components/MetaTags.astro";
import AboutContentItem from "../components/AboutContentItem.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  name: "About — eLife Pathways",
  url: Astro.url.href,
  description:
    "eLife Pathways is dedicated to driving innovation in scholarly communication through interoperable open-source infrastructure.",
  about: {
    "@type": "Organization",
    name: "eLife Pathways",
    url: Astro.url.origin,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <PageHead title="About — eLife Pathways" />
    <MetaTags title="eLife Pathways about page" url={Astro.url.href} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <main>
      <PageHero
        pageTitle="About"
        pageHeading="Dedicated to driving innovation in scholarly communication"
      >
        <p>
          The promise of open science is often hindered by fragmented technology
          and a lack of viable alternatives to traditional, journal-centric
          publishing. Pathways is a new independent initiative designed to
          bridge these gaps by providing the robust infrastructure,
          coordination, and expert support needed for a modern scholarly
          ecosystem. By convening open-source providers and focusing on
          collaboration, we aim to move beyond traditional limitations to
          co-create a future where research is shared equitably and assessed
          responsibly.
        </p>
        <p>
          We redirect eLife’s technical expertise to serve the wider community,
          leveraging the expertise and technology which serves eLife’s journal.
          Recognising that open technologies alone is not enough for widespread
          adoption, we provide the hands-on professional support and open source
          tools necessary to integrate disparate systems into user-friendly,
          interoperable solutions. Through partnerships with other
          infrastructure providers, we eliminate silos and build a resilient,
          shared foundation that offers a sustainable, open alternative for
          research sharing and discovery.
        </p>
      </PageHero>

      <ContentSection>
        <h2>Our Story</h2>
        <p>
          eLife has a rich history of developing and investing in innovation and
          technology. Supporting open science through building open-source
          software and fostering the communities around those tools has always
          been part of eLife’s mission. Since 2012, eLife has been involved in
          many collaborations that have blossomed into impactful open science
          initiatives.
        </p>
      </ContentSection>

      <ContentSection>
        <h2>Who we are</h2>
        <p class="about-team-intro">
          The Pathways technology team operates as a single, agile unit built on
          resilience, lean delivery, and continuous improvement. Our team spans
          software, product, UX, data, and infrastructure—combining these
          technical specialities with a shared, generalist approach to
          problem-solving. The eLife Pathways project is led by:
        </p>
        <ul>
          <li>
            <AboutContentItem
              name="Michael Markie"
              jobTitle="Head of Innovation Initiatives, eLife"
              about="Michael has spent 15 years at the heart of the open science movement. Bringing hands-on experience in scaling open research organisations from the ground up, he played a pivotal role in implementing F1000 Research’s “publish-review-curate” model and launched major publishing platforms for Wellcome, the Gates Foundation, and the European Commission. He also leads the community for Incentivising Collaborative Open Research (ICOR), driven by the belief that the future of scholarly communication depends on collective effort."
              image="images/michael-headshot.png"
            />
          </li>
          <li>
            <AboutContentItem
              name="Paul Shannon"
              jobTitle="Head of Technology, eLife"
              about="Paul has over twenty years' experience in agile and lean software development. Following a career in the digital music technology industry, he joined eLife in 2016 to evolve their engineering department from a single group into a series of specialised, high-performing teams. During his tenure, Paul has overseen the launch of eLife’s open-source journal software, the development of Sciety, while deepening the organisation’s involvement with the wider open ecosystem. He focuses on translating complex technical hurdles into clear objectives, ensuring that modern engineering practices directly support the goals of open science."
              image="images/paul-headshot.png"
            />
          </li>
        </ul>
      </ContentSection>
    </main>
    <Footer />
    <MobileNav />
  </body>
</html>

<style>
  h2 {
    color: var(--color-dark-purple);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    line-height: 1.5;
    margin-block-end: clamp(2rem, calc(1.364rem + 3.182vw), 3.75rem);
  }

  .about-team-intro {
    margin-block-end: clamp(2.5rem, calc(1.227rem + 6.364vw), 6rem);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    margin-block-end: clamp(2.5rem, calc(1.227rem + 6.364vw), 6rem);
  }
</style>

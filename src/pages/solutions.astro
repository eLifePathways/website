---
import "../styles/main.css";
import Footer from "../components/Footer.astro";
import MobileNav from "../components/MobileNav.astro";
import PageHead from "../components/PageHead.astro";
import PageHero from "../components/PageHero.astro";
import ContentSection from "../components/ContentSection.astro";
import MetaTags from "../components/MetaTags.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PageHeroWithEmphasis from "../components/PageHeroWithEmphasis.astro";
import ProjectCardWide from "../components/ProjectCardWide.astro";
import SolutionCard from "../components/SolutionCard.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Solutions — eLife Pathways",
  url: Astro.url.href,
  description:
    "eLife Pathways builds interoperable open-source infrastructure for scholarly communication, offering solutions for open publishing, preprint sharing, peer review, and scholarly metadata.",
  about: {
    "@type": "Organization",
    name: "eLife Pathways",
    url: Astro.url.origin,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <PageHead title="Solutions — eLife Pathways" />
    <MetaTags title="eLife Pathways solutions page" url={Astro.url.href} />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <main>
      <PageHeroWithEmphasis
        pageTitle="Solutions"
        pageHeading="Building open-source publishing software to further open science"
        emphasisText="Through our partnerships, we’re working towards an interoperable and modular publishing ecosystem for the benefit of the global scientific community."
      >
        <p>
          The traditional academic publishing system is outdated. It stifles
          innovation, restricts equity, and fails to adequately connect research
          outputs or support machine-readable science. That’s why eLife Pathways
          exists: to bring people together, foster collaboration across the
          ecosystem, create better ways to share research, and build a strong,
          shared foundation that empowers the global research community.
        </p>
      </PageHeroWithEmphasis>

      <ContentSection>
        <h2>An innovative, open and equitable ecosystem</h2>
        <p>
          Our vision is to build open-source tools that integrate easily with
          both new and existing scholarly systems. By focusing on flexibility
          and shared standards, we enable platforms to work together seamlessly
          and strengthen the open ecosystem.
        </p>
        <div new-feature class="hidden">
          <ul class="solution-cards">
            <li>
              <SolutionCard
                title="Preprinting for earlier sharing and faster publication"
                description="Submit early-stage research outputs and instantly convert them into publication-ready, machine-readable formats."
                iconSrc="/images/solutions-page-icons/fast-sharing.svg"
              />
            </li>
            <li>
              <SolutionCard
                title="Flexible publishing workflows and tooling"
                description="Configure customisable editorial workflows with integrated task management and AI-assisted publishing tools."
                iconSrc="/images/solutions-page-icons/flexible-workflows.svg"
              />
            </li>
          </ul>
        </div>
      </ContentSection>

      <ContentSection>
        <h2>Our Technology</h2>
        <p>
          Through eLife Pathways, we are enhancing and integrating our
          open-source infrastructure to serve the wider open science ecosystem.
          Our established platforms, <a href="https://sciety.org/">Sciety</a> and
          <a href="https://kotahi.foundation/">Kotahi</a>, will be further
          developed to optimise publishing workflows, improve access to open
          research information, and support the needs of modular,
          machine-readable research.
        </p>
        <ul class="project-cards-wide">
          <li>
            <ProjectCardWide
              name="Kotahi"
              description="An open-source, end-to-end publishing platform for preprint servers, preprint review, journals and micropublications. Kotahi supports AI-driven, customisable workflows to make scientific publishing faster, more modular, and machine-readable."
              aboutUrl="https://kotahi.community/"
              githubUrl="https://github.com/elifepathways/kotahi"
              logoSrc="/images/kotahi-logo-48.svg"
            />
          </li>
          <li>
            <ProjectCardWide
              name="Sciety"
              description="Is a free, open-source platform that aggregates preprint evaluations from across the global scholarly network. By bringing discoveries, reviews, and curation into one shared space, Sciety helps researchers filter and discover the latest research."
              aboutUrl="https://sciety.org/"
              githubUrl="https://github.com/sciety/sciety"
              logoSrc="/images/sciety-logo-48.svg"
            />
          </li>
        </ul>
      </ContentSection>

      <ContentSection>
        <h2>Partnerships and Collaborations</h2>
        <p>
          Over the <a
            href="https://elifesciences.org/inside-elife/b6a249af/technology-at-elife-10-years-of-innovation"
            >past decade</a
          >, eLife and its collaborators have built open, community-driven
          software. By adopting shared standards and seamless design, we ensure
          our tools are transparent, reusable, and built to work together.
        </p>
        <ul class="project-cards">
          <li>
            <ProjectCard
              name="COAR Notify"
              description="Decentralised, interoperable standards to link repository research with external services."
              aboutUrl="https://notify.coar-repositories.org/"
              logoSrc="/images/coar-notify-logo-48.svg"
            />
          </li>
          <li>
            <ProjectCard
              name="PREreview"
              description="Enabling researchers to provide and receive constructive feedback on preprints."
              aboutUrl="https://prereview.org/"
              githubUrl="https://github.com/PREreview/prereview.org"
              logoSrc="/images/prereview-logo-48.svg"
            />
          </li>
          <li>
            <ProjectCard
              name="Stencila"
              description="Reproducible, open and interoperable documents with built in scientific intelligence."
              aboutUrl="https://stencila.io/"
              githubUrl="https://github.com/stencila/stencila"
              logoSrc="/images/stencila-logo-48.svg"
            />
          </li>
          <li>
            <ProjectCard
              name="DocMaps"
              description="A community-endorsed framework capturing the context and processes behind document creation."
              aboutUrl="https://docmaps.knowledgefutures.org/"
              githubUrl="https://github.com/Docmaps-Project/docmaps"
              logoSrc="/images/docmaps-logo-48.svg"
            />
          </li>
          <li>
            <ProjectCard
              name="ScienceBeam"
              description="A set of tools working together to generate full XML documents."
              aboutUrl="https://github.com/eLifePathways/sciencebeam-parser"
              logoSrc="/images/sciencebeam-logo-48.svg"
            />
          </li>
          <li>
            <ProjectCard
              name="Hypothesis Publisher Groups"
              description="Using open standards to facilitate open discourse directly on published content for eLife and beyond."
              aboutUrl="https://elifesciences.org/for-the-press/81d42f7d/elife-enhances-open-annotation-with-hypothesis-to-promote-scientific-discussion-online"
              githubUrl="https://github.com/hypothesis/h"
              logoSrc="/images/hypothesis-logo-48.svg"
            />
          </li>
          <li>
            <ProjectCard
              name="eLife Lens"
              description="A novel web experience streamlining the process for researchers, reviewers, authors, and readers."
              aboutUrl="https://lens.elifesciences.org/"
              githubUrl="https://github.com/elifesciences/lens"
              logoSrc="/images/elife-lens-logo-48.svg"
            />
          </li>
        </ul>
      </ContentSection>
    </main>
    <Footer />
    <MobileNav />
  </body><script>
    (() => {
      "use strict";
      if (window.location.search.includes("new-feature")) {
        document.querySelector("[new-feature]").classList.remove("hidden");
      }
    })();
  </script>
</html>

<style>
  h2 {
    color: var(--color-dark-purple);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    line-height: 1.5;
  }

  .hidden {
    display: none;
  }

  .solution-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(30ch, 100%), 1fr));
    gap: 0 var(--space-lg);
    list-style: none;
    margin: 0;
    padding: 0;
    margin-block-start: var(--space-lg);
  }

  .project-cards-wide {
    margin-block-start: var(--space-xl);
    list-style: none;
    padding-inline-start: 0;
  }

  .project-cards-wide li {
    margin-block-end: var(--space-m-xl);
  }

  .project-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(30ch, 1fr));
    gap: var(--space-lg);
    list-style: none;
    margin: 0;
    padding: 0;
    margin-block-start: var(--space-xl);
  }
</style>

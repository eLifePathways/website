---
import "../styles/main.css";
import Footer from "../components/Footer.astro";
import LandingHero from "../components/LandingHero.astro";
import MobileNav from "../components/MobileNav.astro";
import PageHead from "../components/PageHead.astro";
import QuoteFigure from "../components/QuoteFigure.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <PageHead title="eLife Pathways" />
  </head>
  <body>
    <main>
      <LandingHero />

      <section class="homepage-content-section">
        <div class="centered-content-wide columns">
          <div>
            <h2><i>Why</i> eLife Pathways exists<span class="dot"></span></h2>
          </div>
          <div class="flow">
            <p>
              Moving beyond legacy publishing requires interoperable open-source
              infrastructure. With Wellcome’s support, we are evolving eLife’s
              technology to anchor a collaborative network, partnering with the
              open science community to reshape the communication and assessment
              of global research.
            </p>
            <a class="button" href="about">About eLife Pathways</a>
          </div>
        </div>
      </section>

      <section class="homepage-content-section">
        <div class="centered-content-wide columns">
          <div>
            <h2><i>What</i> eLife Pathways does<span class="dot"></span></h2>
          </div>
          <div class="flow">
            <p>
              We listen to the open science community to build the
              infrastructure and technology essential for equitable, global
              research communication. Our tools are free to use, adapt, and
              extend, allowing us to partner with others to explore innovative
              ways to share and discover research.
            </p>
            <a class="button" href="solutions">Read about our solutions</a>
          </div>
        </div>
      </section>

      <section class="homepage-content-section">
        <div class="centered-content-wide columns">
          <div>
            <h2>
              <i>Who</i> eLife Pathways works with<span class="dot"></span>
            </h2>
          </div>
          <div class="flow">
            <p>
              We work with like-minded organisations, open source technologists
              and communities of researchers who want to co-create the
              sustainable technology needed for a more inclusive and effective
              scholarly communication ecosystem.
            </p>
            <a class="button" href="partnerships">Read about our partnerships</a
            >
          </div>
        </div>
      </section>

      <section class="centered-content-wide wrapper">
        <QuoteFigure
          quote="The change we seek in preprint review and scholarly communication cannot be driven by any one person or organization—it must emerge from communities working together. eLife Pathways helps build the infrastructure to strengthen those connections and enable the co-evolution of tools and communities."
          headshotSrc="images/daniela-saderi.png"
          headshotAlt="Headshot of Daniela Saderi"
          name="Daniela Saderi"
          jobTitle="Executive Director"
          logoSrc="images/prereview-logo.svg"
          logoAlt="PreReview"
        />
        <QuoteFigure
          quote="Advancing a preprint-first culture requires a shared commitment. eLife Pathways helps to build a trustworthy and interconnected ecosystem that prioritises transparency, connection, and mutual trust."
          headshotSrc="images/tracy-teal.png"
          headshotAlt="Headshot of Tracy Teal"
          name="Tracy Teal"
          jobTitle="CEO"
          logoSrc="images/openrxiv-logo.png"
          logoAlt="OpenRxiv"
        />
      </section>
    </main>

    <Footer />
    <MobileNav />
  </body>
</html>

<style>
  .homepage-content-section {
    margin-block-end: var(--large-vertical-space);
  }

  .homepage-content-section h2 i {
    color: var(--color-pink);
  }

  .wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 1.875rem;
  }
</style>

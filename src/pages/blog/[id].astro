---
import "../../styles/main.css";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import ContentSection from "../../components/ContentSection.astro";
import Footer from "../../components/Footer.astro";
import MobileNav from "../../components/MobileNav.astro";
import PageHead from "../../components/PageHead.astro";
import PageHero from "../../components/PageHero.astro";
import MetaTags from "../../components/blog/MetaTags.astro";
import { formatDate } from "../../components/formatDate";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { id: post.id } }));
}

const { id } = Astro.params;
const posts = await getCollection("blog");
const post = posts.find((p) => p.id === id)!;
const { Content } = await render(post);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "url": Astro.url.href,
  "datePublished": post.data.date.toISOString(),
  ...(post.data.summary && { "description": post.data.summary }),
  ...(post.data.image && { "image": new URL(post.data.image.src, Astro.url.origin).href }),
  "publisher": {
    "@type": "Organization",
    "name": "eLife Pathways",
    "url": Astro.url.origin,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <PageHead title={`${post.data.title} — eLife Pathways`} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <MetaTags
      title={post.data.title}
      url={Astro.url.href}
      origin={Astro.url.origin}
      date={post.data.date}
      summary={post.data.summary}
      image={post.data.image}
      imageAlt={post.data.imageAlt}
    />
  </head>
  <body>
    <main>
      <PageHero
        backNavTarget="/blog"
        pageTitle="Blog"
        pageHeading={post.data.title}
      >
        {post.data.summary && <p class="summary">{post.data.summary}</p>}
        {
          post.data.image && (
            <Image
              src={post.data.image}
              alt={post.data.imageAlt}
              widths={[640, 960, 1280]}
              sizes="(min-width: 60rem) 960px, 100vw"
              loading="eager"
            />
          )
        }
      </PageHero>
      <ContentSection>
        <div class="markdown-content flow">
          <time
            class="blog-card__date"
            datetime={post.data.date.toISOString().slice(0, 10)}
          >
            {formatDate(post.data.date)}
          </time>
          <Content />
        </div>
      </ContentSection>
    </main>
    <Footer />
    <MobileNav />
  </body>
</html>

<style>
  .markdown-content {
    blockquote {
      border-inline-start: 6px solid var(--color-brand-elife-pink);
      padding-inline-start: var(--space-md);
      margin-block: var(--space-xl);
    }
    blockquote :last-child {
      font-weight: var(--font-weight-semibold);
    }
    time {
      font-size: var(--font-size-sm);
    }
    --flow-space: var(--space-lg);
  }

  .summary {
    font-weight: var(--font-weight-semibold);
    color: var(--color-dark-purple);
    margin-block-end: var(--space-xl);
  }
</style>

---
interface Props {
  name: string;
  description: string;
  aboutUrl: string;
  githubUrl: string;
  logoSrc: string;
  logoAlt?: string;
}

const { name, description, aboutUrl, githubUrl, logoSrc, logoAlt } =
  Astro.props;
---

<div class="project-card">
  <div class="project-card__logo">
    <img src={logoSrc} alt={logoAlt ?? name} />
  </div>
  <p class="project-card__description">{description}</p>
  <div class="project-card__links">
    <a class="project-card__link" href={aboutUrl} rel="noopener noreferrer">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M8 2H2v12h12V8h-2v4H4V4h4V2zm2 0v2h1.586L7 8.586 8.414 10 13 5.414V7h2V2h-5z"
          fill="currentColor"></path>
      </svg>
      About
    </a>
    <a class="project-card__link" href={githubUrl} rel="noopener noreferrer">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
          fill="currentColor"></path>
      </svg>
      Github
    </a>
  </div>
</div>

<style>
  .project-card {
    background-color: var(--color-cream);
    border-radius: 0.75rem;
    padding: var(--space-md);
    box-shadow: 0 1px 6px rgb(0 0 0 / 0.08);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .project-card__logo {
    height: 2rem;
    display: flex;
    align-items: center;
  }

  .project-card__logo img {
    max-height: 100%;
    max-width: 10rem;
    object-fit: contain;
    object-position: left center;
  }

  .project-card__description {
    flex: 1;
    font-size: var(--font-size-sm);
    color: var(--color-peach-text);
    line-height: var(--line-height-base);
    margin: 0;
  }

  .project-card__links {
    display: flex;
    gap: var(--space-md);
    margin-block-start: var(--space-xs);
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-pink);
    text-decoration: none;
  }

  .project-card__link:hover {
    text-decoration: underline;
  }

  .project-card__link svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }
</style>

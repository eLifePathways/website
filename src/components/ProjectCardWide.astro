---
interface Props {
  name: string;
  description: string;
  aboutUrl: string;
  githubUrl?: string;
  logoSrc: string;
}

const { name, description, aboutUrl, githubUrl, logoSrc } = Astro.props;
---

<article class="project-card-wide" data-card-colour-scheme={name}>
  <h3>
    <img src={logoSrc} alt={name} />
  </h3>
  <p class="project-card-wide-description">{description}</p>
  <div class="project-card-wide-links">
    <a class="project-card-wide-link" href={aboutUrl} rel="noopener noreferrer">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        aria-hidden="true"
        focusable="false"
      >
        <path
          d="M8 2H2v12h12V8h-2v4H4V4h4V2zm2 0v2h1.586L7 8.586 8.414 10 13 5.414V7h2V2h-5z"
          fill="currentColor"></path>
      </svg>
      About
    </a>
    {
      githubUrl && (
        <a
          class="project-card-wide-link"
          href={githubUrl}
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            aria-hidden="true"
            focusable="false"
          >
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
              fill="currentColor"
            />
          </svg>
          Github
        </a>
      )
    }
  </div>
</article>

<style>
  .project-card-wide {
    border-radius: var(--card-border-radius);
    padding: clamp(1.5rem, calc(1.136rem + 1.818vw), 2.5rem);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  h3 {
    margin-block-start: 0;
  }

  h3 img {
    width: 156px;
    height: 69px;
    object-fit: contain;
    object-position: left center;
  }

  .project-card-wide-description {
    font-size: clamp(0.875rem, calc(0.83rem + 0.227vw), 1rem);
    color: var(--color-peach-text);
    line-height: var(--line-height-base);
    margin: 0;
  }

  .project-card-wide-links {
    display: flex;
    gap: var(--space-md);
    margin-block-start: var(--space-xs);
  }

  .project-card-wide[data-card-colour-scheme="Kotahi"] {
    background-color: var(--color-kotahi-light-green);
  }

  .project-card-wide[data-card-colour-scheme="Sciety"] {
    background-color: var(--color-sciety-light-orange);
  }

  .project-card-wide[data-card-colour-scheme="Kotahi"] .project-card-wide-link {
    color: var(--color-kotahi-dark-green);
  }

  .project-card-wide[data-card-colour-scheme="Sciety"] .project-card-wide-link {
    color: var(--color-sciety-dark-orange);
  }

  .project-card-wide-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
  }

  .project-card-wide-link:hover {
    text-decoration: underline;
  }

  .project-card-wide-link svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }
</style>

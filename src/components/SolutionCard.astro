---
interface Props {
  title: string;
  description: string;
  iconSrc: string;
}

const { title, description, iconSrc } = Astro.props;
---

<article class="solution-card">
  <div class="solution-card-heading">
    <img class="solution-card-icon" src={iconSrc} alt="" />
    <h3>{title}</h3>
  </div>
  <p class="solution-card-description">{description}</p>
</article>

<style>
  .solution-card {
    height: 100%;
    border-block: 1px solid #1b0a3c26;
    padding-block-start: var(--space-md);
    padding-block-end: var(--space-lg);
  }

  .solution-card-heading {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .solution-card-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    padding: var(--space-xs);
    background-color: #fff2e1;
    border-radius: 4px;
  }

  h3 {
    margin: 0;
    color: var(--color-dark-purple);
    font-size: var(--font-size-sm-to-base);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-base);
  }

  .solution-card-description {
    margin: 0;
    margin-block-start: 1.125rem;
    color: var(--color-dark-purple);
    font-size: var(--font-size-sm-to-base);
    line-height: var(--line-height-base);
  }
</style>

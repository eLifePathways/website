---
interface Props {
  quote: string;
  headshotSrc: string;
  headshotAlt: string;
  name: string;
  jobTitle: string;
  logoSrc: string;
  logoAlt: string;
}

const { quote, headshotSrc, headshotAlt, name, jobTitle, logoSrc, logoAlt } =
  Astro.props;
---

<figure class="figure">
  <blockquote>{quote}</blockquote>
  <figcaption class="attribution">
    <div class="biography">
      <img class="quote-headshot" src={headshotSrc} alt={headshotAlt} />
      <div>
        <div><b>{name}</b></div>
        <div>{jobTitle}</div>
      </div>
    </div>
    <div class="logo">
      <img src={logoSrc} alt={logoAlt} />
    </div>
  </figcaption>
</figure>

<style>
  .figure {
    background-color: var(--color-cream-quote);
    flex: 1 0 17rem;
    max-width: 30.3125rem;
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.25rem;
  }

  .attribution {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .biography {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .quote-headshot {
    width: 80px;
    height: 80px;
    border-radius: 400px;
  }

  .logo {
    width: 104px;
    margin-left: auto;
  }
</style>

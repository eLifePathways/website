---
interface Props {
  quote: string;
  headshotSrc: string;
  headshotAlt: string;
  name: string;
  jobTitle: string;
  logoSrc: string;
  logoAlt: string;
}

const { quote, headshotSrc, headshotAlt, name, jobTitle, logoSrc, logoAlt } =
  Astro.props;
---

<figure class="figure">
  <blockquote>{quote}</blockquote>
  <figcaption>
    <img class="quote-headshot" src={headshotSrc} alt={headshotAlt} />
    <div>{name}</div>
    <div>{jobTitle}</div>
    <img class="logo" src={logoSrc} alt={logoAlt} />
  </figcaption>
</figure>

<style>
  .quote-headshot {
    width: 80px;
    height: 80px;
    border-radius: 400px;
  }

  .logo {
    width: 104px;
  }

  .figure {
    background-color: var(--color-cream-quote);
    flex: 1 0 26.5625rem;
    padding: 2.25rem;
  }
</style>

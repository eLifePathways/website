---
import SiteNav from './SiteNav.astro';
---

<header class="landing-hero" id="site-header">
  <SiteNav />
  <div class="flow hero-inner">
    <h1><span>Building <em>better</em> ways</span><span>to share research<span class="hero-dot" aria-hidden="true"></span></span></h1>
    <p class="hero-body">An open-source initiative from eLife dedicated to co-creating a more connected and collaborative open science ecosystem.</p>
  </div>
</header>

<style>
.landing-hero {
  --hero-arc-y: 60px;

  height: var(--hero-height-default);
  padding-top: var(--space-sm);
  display: flex;
  flex-direction: column;
  justify-content: center;
  background:
    url("../assets/hero-arc.svg") center var(--hero-arc-y) / 100% 100% no-repeat,
    var(--gradient-peach-1);
}

.landing-hero h1 > span {
  display: block;
}

.landing-hero h1 {
  font-size: clamp(26px, 8vw, 40px);
  font-weight: var(--font-weight-regular);
  line-height: 1.05;
  letter-spacing: -0.02rem;
  color: var(--color-dark-purple);
}

.landing-hero h1 em {
  color: var(--color-pink);
  font-style: italic;
}

.hero-body {
  color: var(--color-dark-purple);
  font-size: clamp(var(--font-size-sm), 3vw, var(--font-size-lg));
  line-height: 1.55;
}

.hero-dot {
  display: inline-block;
  position: relative;
  top: 2px;
  left: 6px;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: var(--color-pink);
  vertical-align: baseline;
}

@media (min-width: 30rem) {
  .hero-dot {
    width: 14px;
    height: 14px;
  }

  .landing-hero {
    --hero-arc-y: 80px;
    height: var(--hero-height-sm);
    padding-top: var(--space-md);
  }
}

@media (min-width: 40rem) {
  .hero-dot {
    width: 18px;
    height: 18px;
  }

  .landing-hero {
    --hero-arc-y: 100px;
    height: var(--hero-height-md);
    padding-top: var(--space-lg);
  }
}

@media (min-width: 50rem) {
  .hero-dot {
    width: 20px;
    height: 20px;
  }

  .landing-hero {
    --hero-arc-y: 130px;
    height: var(--hero-height-lg);
    padding-top: var(--space-lg);
  }
}

@media (min-width: 75rem) {
  .landing-hero {
    --hero-arc-y: 165px;
    height: var(--hero-height-xl);
    padding-top: var(--space-xl);
  }
}

  .hero-inner {
  text-align: center;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: var(--space-md);
}

@media (min-width: 30rem /* sm = 480px */) {
  .hero-inner h1 {
    font-size: clamp(26px, 8vw, 50px);
  }
}

@media (min-width: 40rem /* md = 640px */) {
  .hero-inner h1 {
    font-size: clamp(50px, 7vw, 70px);
  }
}

@media (min-width: 50rem /* 800px */) {
  .hero-inner {
    padding-inline: 7%;
  }

  .hero-inner h1 {
    font-size: clamp(60px, 7vw, 80px);
  }
  }
@media (min-width: 75rem /* 1200px */) {

  .hero-inner {
    padding: 0 150px;
  }

  .hero-inner h1 {
  margin-bottom: var(--space-md);
    font-size: var(--font-size-4xl);
  }
}
</style>

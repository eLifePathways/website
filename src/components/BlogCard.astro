---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { formatDate } from "./formatDate";

interface Props {
  title: string;
  date: Date;
  image?: ImageMetadata;
  href: string;
}

const { title, date, image, href } = Astro.props;
---

<li class="blog-card">
  <a class="blog-card__link" href={href}>
    <div class="blog-card__image">
      {image && <Image src={image} alt="" widths={[320, 640]} sizes="(min-width: 40rem) 320px, 100vw" />}
    </div>
    <div class="blog-card__body">
      <h3 class="blog-card__title">{title}</h3>
      <time class="blog-card__date" datetime={date.toISOString().slice(0, 10)}>
        {formatDate(date)}
      </time>
    </div>
  </a>
</li>

<style>
  .blog-card {
    list-style: none;
  }

  .blog-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: var(--color-cream);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 1px 6px rgb(0 0 0 / 0.08);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 200ms ease;
  }

  .blog-card__link:hover {
    box-shadow: 0 4px 16px rgb(0 0 0 / 0.14);
  }

  .blog-card__image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-cream);
  }

  .blog-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-card__body {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .blog-card__title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-semibold);
    color: var(--color-dark-purple);
    line-height: var(--line-height-snug);
    margin: 0;
  }

  .blog-card__date {
    font-size: var(--font-size-sm);
    color: var(--color-peach-text);
    line-height: var(--line-height-base);
  }
</style>

---
import SiteNav from './SiteNav.astro';

interface Props {
  pageTitle: string;
  pageHeading: string;
}

const { pageTitle, pageHeading } = Astro.props;
---

<header class="landing-hero" data-theme="hero">
  <SiteNav />
  <div class="[ wrapper ] [ flow ] hero-inner">
    <p class="section-label">{pageTitle}</p>
    <h1>{pageHeading}<em>.</em></h1>
    <slot />
  </div>
</header>

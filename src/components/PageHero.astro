---
import SiteNav from './SiteNav.astro';

interface Props {
  pageTitle: string;
  pageHeading: string;
}

const { pageTitle, pageHeading } = Astro.props;
---

<header class="page-hero" id="site-header">
  <SiteNav />
  <div class="flow hero-inner">
    <p class="section-label">{pageTitle}</p>
    <h1>{pageHeading}<em>.</em></h1>
    <slot />
  </div>
</header>

<style>
  .hero-inner {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: 0;
}

@media (min-width: 30rem /* sm = 480px */) {
  .hero-inner h1 {
    font-size: clamp(26px, 8vw, 50px);
  }
}

@media (min-width: 40rem /* md = 640px */) {
  .hero-inner h1 {
    font-size: clamp(50px, 7vw, 70px);
  }

@media (min-width: 50rem /* 800px */) {

  .hero-inner h1 {
    font-size: clamp(60px, 7vw, 80px);
  }
  }
@media (min-width: 75rem /* 1200px */) {

  .hero-inner {
    padding: 0 150px;
  }

  .hero-inner h1 {
  margin-bottom: var(--space-md);
    font-size: var(--font-size-4xl);
  }
}
}
</style>

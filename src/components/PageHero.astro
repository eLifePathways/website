---
import SiteNav from "./SiteNav.astro";

interface Props {
  pageTitle: string;
  pageHeading: string;
}

const { pageTitle, pageHeading } = Astro.props;
---

<header class="page-hero" id="site-header">
  <SiteNav />
  <div class="centered-content flow hero-inner">
    <p class="section-label">{pageTitle}</p>
    <h1>{pageHeading}<em>.</em></h1>
    <slot />
  </div>
</header>

<style>
  .page-hero {
    min-height: var(--hero-height-default);
    padding-top: var(--space-sm);
    background-color: var(--color-cream);
    color: var(--color-peach-text);
    margin-block-end: var(--vertical-space-between-sections);
  }

  .page-hero h1 > span {
    display: block;
  }

  .page-hero h1 {
    font-size: clamp(26px, 8vw, 40px);
    font-weight: var(--font-weight-regular);
    line-height: 1.05;
    letter-spacing: -0.02rem;
    color: var(--color-dark-purple);
  }

  .page-hero h1 em {
    color: var(--color-pink);
    font-style: normal;
  }

  @media (min-width: 30rem) {
    .page-hero {
      min-height: var(--hero-height-sm);
      padding-top: var(--space-md);
    }
  }

  @media (min-width: 40rem) {
    .page-hero {
      min-height: var(--hero-height-md);
      padding-top: var(--space-lg);
    }
  }

  @media (min-width: 50rem) {
    .page-hero {
      min-height: var(--hero-height-lg);
      padding-top: var(--space-lg);
    }
  }

  @media (min-width: 75rem) {
    .page-hero {
      min-height: var(--hero-height-xl);
      padding-top: var(--space-xl);
    }
  }

  .section-label {
    color: var(--color-pink);
    font-weight: var(--font-weight-semibold);
  }

  .hero-inner {
    width: 100%;
    margin-top: clamp(2rem, calc(-1.341rem + 16.705vw), 11.188rem);
  }

  @media (min-width: 30rem /* sm = 480px */) {
    .hero-inner h1 {
      font-size: clamp(26px, 8vw, 50px);
    }
  }

  @media (min-width: 40rem /* md = 640px */) {
    .hero-inner h1 {
      font-size: clamp(50px, 7vw, 4.4375rem);
    }
  }

  @media (min-width: 50rem /* 800px */) {
    .hero-inner h1 {
      font-size: clamp(60px, 7vw, 4.4375rem);
    }
  }
  @media (min-width: 75rem /* 1200px */) {
    .hero-inner h1 {
      margin-bottom: var(--space-md);
      line-height: calc(78 / 71);
      font-size: 4.4375rem; /* 71px */
    }
  }
</style>
